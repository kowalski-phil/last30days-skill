# last30days fork — OpenRouter + Apify edition
# Copy this file to .env and fill in your keys:
#   cp .env.example .env

# Required — unified LLM gateway (get key at openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-your-key-here

# Required — unified scraping platform (get key at console.apify.com)
APIFY_API_TOKEN=apify_api_your-token-here

# Optional — override the default LLM model
# OPENROUTER_MODEL=google/gemini-3.1-flash-lite-preview
